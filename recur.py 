def nuc_abC1(a,b,C):
    '''
    Nuclear attraction integrals for m =+1,-1 components. 
    '''
    
    l1,m1,n1 = a.shell
    l2,m2,n2 = b.shell
    VabC1 = 0.0 
    
    for ia,ca in enumerate(a.coeffs):
        for ib,cb in enumerate(b.coeffs):
            
            part2 = 0
            part3 = 0
            part2 = ((m1*n2*nuc_att(a.alphas[ia],a.shell,a.origin,b.alphas[ib],b.shell,b.origin,C,'na05'))\
                     -(2*b.alphas[ib]*m1*nuc_att(a.alphas[ia],a.shell,a.origin,b.alphas[ib],b.shell,b.origin,C,'na06'))\
                     -(2*a.alphas[ia]*n2*nuc_att(a.alphas[ia],a.shell,a.origin,b.alphas[ib],b.shell,b.origin,C,'na07'))\
                     +(4*a.alphas[ia]*b.alphas[ib]*nuc_att(a.alphas[ia],a.shell,a.origin,b.alphas[ib],b.shell,b.origin,C,'na08'))\
                     -(n1*m2*nuc_att(a.alphas[ia],a.shell,a.origin,b.alphas[ib],b.shell,b.origin,C,'na05'))\
                     +(2*b.alphas[ib]*n1*nuc_att(a.alphas[ia],a.shell,a.origin,b.alphas[ib],b.shell,b.origin,C,'na07'))\
                     +(2*a.alphas[ia]*m2*nuc_att(a.alphas[ia],a.shell,a.origin,b.alphas[ib],b.shell,b.origin,C,'na06'))\
                     -(4*a.alphas[ia]*b.alphas[ib]*nuc_att(a.alphas[ia],a.shell,a.origin,b.alphas[ib],b.shell,b.origin,C,'na08')))

            part3 = ((n1*l2*nuc_att(a.alphas[ia],a.shell,a.origin,b.alphas[ib],b.shell,b.origin,C,'na09'))\
                     -(2*b.alphas[ib]*n1*nuc_att(a.alphas[ia],a.shell,a.origin,b.alphas[ib],b.shell,b.origin,C,'na10'))\
                     -(2*a.alphas[ia]*l2*nuc_att(a.alphas[ia],a.shell,a.origin,b.alphas[ib],b.shell,b.origin,C,'na11'))\
                     +(4*a.alphas[ia]*b.alphas[ib]*nuc_att(a.alphas[ia],a.shell,a.origin,b.alphas[ib],b.shell,b.origin,C,'na12'))\
                     -(l1*n2*nuc_att(a.alphas[ia],a.shell,a.origin,b.alphas[ib],b.shell,b.origin,C,'na09'))\
                     +(2*b.alphas[ib]*l1*nuc_att(a.alphas[ia],a.shell,a.origin,b.alphas[ib],b.shell,b.origin,C,'na11'))
                     +(2*a.alphas[ia]*n2*nuc_att(a.alphas[ia],a.shell,a.origin,b.alphas[ib],b.shell,b.origin,C,'na10'))\
                     -(4*a.alphas[ia]*b.alphas[ib]*nuc_att(a.alphas[ia],a.shell,a.origin,b.alphas[ib],b.shell,b.origin,C,'na12')))

            VabC1 += a.norm[ia]*b.norm[ib]*ca*cb*(part2 + (1j*part3))
            
            
    return VabC1

def nuc_ab1():
    natoms = len(atoms)
    Vab1 = np.zeros([nbasis, nbasis], dtype = 'complex_')
    for a in range(nbasis):
        for b in range(nbasis):
            for i in range(natoms):
                Vab1[a,b] += -1j*Z[atoms[i]]*nuc_abC1(list_bf[a],list_bf[b],C[i])
        
    return Vab1

